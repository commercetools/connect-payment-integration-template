{
  "name": "payment-integration-template",
  "version": "4.9.0",
  "description": "Payment provider integration template",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "node_modules/.bin/nodemon -q dist/main.js",
    "lint": "prettier --check \"**/**/*.{ts,js,json}\" && eslint src test",
    "lint:fix": "prettier --write \"**/**/*.{ts,js,json}\" && eslint --fix src test",
    "build": "rm -rf /dist && tsc",
    "dev": "ts-node src/main.ts",
    "watch": "nodemon --watch \"src/**\" --ext \"ts,json\" --ignore \"src/**/*.spec.ts\" --exec \"ts-node src/main.ts\"",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "connector:post-deploy": "node dist/connectors/post-deploy.js",
    "connector:pre-undeploy": "node dist/connectors/pre-undeploy.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@commercetools-backend/loggers": "27.6.0",
    "@commercetools/connect-payments-sdk": "0.28.0",
    "@fastify/autoload": "6.3.1",
    "@fastify/cors": "11.2.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/http-proxy": "11.4.4",
    "@fastify/request-context": "6.2.1",
    "@fastify/static": "9.1.3",
    "@fastify/type-provider-typebox": "6.1.0",
    "@sinclair/typebox": "0.34.49",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.8.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "jest": "30.4.2",
    "msw": "2.14.6",
    "node-fetch": "3.3.2",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "path-to-regexp": "3.3.0",
    "lodash": "4.18.1",
    "@typescript-eslint/utils": "8.58.2",
    "@babel/runtime": "7.26.10",
    "@babel/runtime-corejs3": "7.26.10",
    "brace-expansion": "1.1.14",
    "diff": "9.0.0",
    "flatted": "3.4.2",
    "minimatch": "3.1.5"
  }
}
